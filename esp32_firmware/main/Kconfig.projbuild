menu "ECG Project Configuration"

config ECG_WIFI_SSID
    string "WiFi SSID"
    default "your_ssid"

config ECG_WIFI_PASSWORD
    string "WiFi Password"
    default "your_password"

config ECG_MQTT_BROKER_URI
    string "MQTT Broker URI"
    default "mqtt://192.168.1.100"

config ECG_MQTT_TOPIC
    string "MQTT Topic"
    default "/ecg/data"

config ECG_MQTT_QOS
    int "MQTT QoS"
    default 1

endmenu
